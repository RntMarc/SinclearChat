DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sinclearchat
DB_USER=root
DB_PASSWORD=

# v1 (unverändert)
SHARED_SECRET=your-secret-key-here-change-in-production
HMAC_HEADER_PREFIX=X-Hub

# v2 - JWT (RS256)
JWT_API_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...base64 content...
-----END PUBLIC KEY-----"
JWT_API_ISSUER=https://app.sinclear.de
JWT_API_AUDIENCE=chat-api
JWT_API_ACCESS_TTL=900
JWT_API_REFRESH_TTL=2592000

# v2 - Internal API (HMAC mit eigenem Secret, separat vom v1 SHARED_SECRET)
AUTH_INTERNAL_SECRET=separate-internal-secret-for-v2-auth
INTERNAL_HMAC_PREFIX=X-Internal

# Allgemein
DEFAULT_TTL_DAYS=30
MAX_MESSAGE_LIMIT=200
DEFAULT_MESSAGE_LIMIT=50

# Storage (Uploads)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/var/sinclearchat/uploads
STORAGE_LOCAL_PUBLIC_URL=https://chat.sinclear.de/files
MAX_UPLOAD_SIZE_BYTES=10485760

# SSE
SSE_HEARTBEAT_INTERVAL=25
SSE_HISTORY_RETENTION_MINUTES=15

# CORS
CORS_ORIGIN=*
